<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <title>Welcome</title>
</head>

<body class="min-h-screen bg-gradient-to-br from-teal-900 via-blue-900 to-gray-900 text-white">

  <!-- Navbar -->
  <nav class="flex justify-between items-center px-6 py-4 bg-white/10 backdrop-blur-md border-b border-white/20">
    <h1 class="text-xl font-bold">MyApp</h1>
    <div class="space-x-4">
      <a href="/users/login" class="hover:underline">Login</a>
      <a href="/users/register" class="bg-white/20 px-4 py-2 rounded-lg hover:bg-white/30 transition">
        Register
      </a>
    </div>
  </nav>

  <!-- Hero Section -->
  <div class="flex flex-col items-center justify-center text-center px-6 py-20">

    <h1 class="text-4xl md:text-5xl font-bold mb-6">
      Build Something Amazing 🚀
    </h1>

    <p class="text-gray-200 max-w-xl mb-8">
      A modern platform with a clean UI. Fast, secure, and designed for a seamless experience.
    </p>

    <div class="space-x-4">
      <a href="/users/login" 
         class="bg-gradient-to-r from-teal-500 via-blue-600 to-teal-700 px-6 py-3 rounded-lg font-semibold shadow-md hover:scale-105 transition">
        Get Started
      </a>

      <a href="/users/register" 
         class="border border-white/30 px-6 py-3 rounded-lg hover:bg-white/10 transition">
        Create Account
      </a>
    </div>

  </div>

  <!-- Features Section -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 px-6 pb-16">

    <div class="bg-white/10 backdrop-blur-md p-6 rounded-xl text-center hover:scale-105 transition">
      <h3 class="font-semibold text-lg mb-2">Fast</h3>
      <p class="text-sm text-gray-200">Optimized for performance and speed</p>
    </div>

    <div class="bg-white/10 backdrop-blur-md p-6 rounded-xl text-center hover:scale-105 transition">
      <h3 class="font-semibold text-lg mb-2">Secure</h3>
      <p class="text-sm text-gray-200">Your data is safe and protected</p>
    </div>

    <div class="bg-white/10 backdrop-blur-md p-6 rounded-xl text-center hover:scale-105 transition">
      <h3 class="font-semibold text-lg mb-2">Modern UI</h3>
      <p class="text-sm text-gray-200">Clean and user-friendly design</p>
    </div>

  </div>

</body>
</html>