<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Budget</title>
</head>
<body>
    <h1>Budget API</h1>
    <form action="/setgoals" method="post">
      
      <input 
        type="text" 
        id="misssion"
        name="misssion"
        placeholder="Mission"
        required
      >

      
      <input 
        type="number" 
        id="target"
        name="target"
        placeholder="Target Amount"
        required
      >

      <input 
        type="number" 
        id="savings"
        name="savings"
        placeholder="Savings Amount"
        required
      >
       <input 
        type="text" 
        id="deadline"
        name="deadline"
        placeholder="Deadline"
        required
      > 

      <button 
        type="submit" 
      >
      Process
      </button>

    </form>

    
</body>
</html>