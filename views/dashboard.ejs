<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <title>Dashboard</title>
</head>

<body class="bg-gradient-to-br from-teal-900 via-blue-900 to-gray-900 min-h-screen text-white">

  <!-- Navbar -->
  <nav class="flex justify-between items-center px-6 py-4 bg-white/10 backdrop-blur-md border-b border-white/20">
    <h1 class="text-xl font-bold">MyApp</h1>
    <button class="bg-white/20 px-4 py-2 rounded-lg hover:bg-white/30 transition">
     <a href="/users/logout"> Logout</a>
    </button>
  </nav>

  <!-- Main Content -->
  <div class="p-6">

    <!-- Welcome -->
    <h2 class="text-2xl font-semibold mb-6">Welcome <%= user %></h2>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <div class="bg-white/10 backdrop-blur-md p-6 rounded-xl shadow-lg hover:scale-105 transition">
        <h3 class="text-lg font-semibold mb-2">Profile</h3>
        <p class="text-sm text-gray-200">View and edit your profile</p>
      </div>

      <div class="bg-white/10 backdrop-blur-md p-6 rounded-xl shadow-lg hover:scale-105 transition">
        <h3 class="text-lg font-semibold mb-2">Settings</h3>
        <p class="text-sm text-gray-200">Manage preferences</p>
      </div>

      <div class="bg-white/10 backdrop-blur-md p-6 rounded-xl shadow-lg hover:scale-105 transition">
        <h3 class="text-lg font-semibold mb-2">Analytics</h3>
        <p class="text-sm text-gray-200">Check your activity</p>
      </div>

    </div>

  </div>

</body>
</html>