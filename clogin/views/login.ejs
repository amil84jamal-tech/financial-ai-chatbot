<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Finni | Login</title>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, Helvetica, sans-serif;
        }

        body{
            background:#000;
            color:white;
            height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            padding:20px;
        }

        .container{
            width:100%;
            max-width:420px;
            padding:40px;
            background:#111;
            border-radius:20px;
            border:1px solid rgba(29,185,84,0.2);
            box-shadow:0 0 30px rgba(29,185,84,0.12);
        }

        .logo{
            text-align:center;
            font-size:2.7rem;
            color:#1DB954;
            font-weight:bold;
            margin-bottom:10px;
        }

        .subtitle{
            text-align:center;
            color:#9a9a9a;
            margin-bottom:30px;
            font-size:0.95rem;
            line-height:1.5;
        }

        form{
            display:flex;
            flex-direction:column;
            gap:18px;
        }

        input{
            width:100%;
            padding:14px;
            border:none;
            border-radius:12px;
            background:#1a1a1a;
            color:white;
            outline:none;
            font-size:1rem;
            border:1px solid transparent;
            transition:0.3s;
        }

        input:focus{
            border:1px solid #1DB954;
            box-shadow:0 0 10px rgba(29,185,84,0.25);
        }

        button{
            padding:14px;
            border:none;
            border-radius:12px;
            background:#1DB954;
            color:black;
            font-weight:bold;
            font-size:1rem;
            cursor:pointer;
            transition:0.3s;
        }

        button:hover{
            transform:translateY(-2px);
            opacity:0.92;
        }

        .footer{
            margin-top:22px;
            text-align:center;
            color:#8a8a8a;
            font-size:0.95rem;
        }

        .footer a{
            color:#1DB954;
            text-decoration:none;
            font-weight:bold;
        }

        .footer a:hover{
            text-decoration:underline;
        }

        /* SUCCESS MESSAGE */

        .success-list{
            list-style:none;
            margin-top:20px;
        }

        .success-list li{
            background:rgba(29,185,84,0.12);
            border:1px solid rgba(29,185,84,0.3);
            color:#7dffab;
            padding:14px;
            border-radius:12px;
            font-size:0.92rem;
            text-align:center;
            animation:fadeIn 0.3s ease;
        }

        /* ERROR MESSAGE */

        .error-list{
            list-style:none;
            margin-bottom:20px;
        }

        .error-list li{
            background:rgba(255,77,77,0.12);
            border:1px solid rgba(255,77,77,0.3);
            color:#ff7b7b;
            padding:14px;
            border-radius:12px;
            font-size:0.92rem;
            text-align:center;
            animation:fadeIn 0.3s ease;
        }

        @keyframes fadeIn{

            from{
                opacity:0;
                transform:translateY(-5px);
            }

            to{
                opacity:1;
                transform:translateY(0);
            }

        }

        @media(max-width:500px){

            .container{
                padding:30px 20px;
            }

            .logo{
                font-size:2.2rem;
            }

        }

    </style>

</head>
<body>

    <div class="container">

        <div class="logo">Finni</div>

        <div class="subtitle">
            Your AI Finance Companion
        </div>

        <!-- SUCCESS MESSAGE -->

        <% if(messages.success_msg){ %>

            <ul class="success-list">

                <li>
                    ✓ <%= messages.success_msg %>
                </li>

            </ul>

        <% } %>

        <!-- ERROR MESSAGE -->

        <% if(messages.error){ %>

            <ul class="error-list">

                <li>
                    ⚠ <%= messages.error %>
                </li>

            </ul>

        <% } %>

        <!-- LOGIN FORM -->

        <form action="/users/login" method="post">

            <input 
                type="email"
                id="email"
                name="email"
                placeholder="E-Mail Address"
                required
            >  

            <input 
                type="password"
                id="password"
                name="password"
                placeholder="Password"
                required
            > 

            <button type="submit">
                Login
            </button>

        </form>

        <div class="footer">
            New to Finni?
            <a href="/users/register">Create Account</a>
        </div>

    </div>

</body>
</html>