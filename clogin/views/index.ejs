<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Finn | AI Financial Assistant</title>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, Helvetica, sans-serif;
        }

        body{
            background:#000;
            color:white;
            min-height:100vh;
        }

        nav{
            width:100%;
            padding:20px 8%;
            display:flex;
            justify-content:space-between;
            align-items:center;
            border-bottom:1px solid rgba(255,255,255,0.08);
            position:sticky;
            top:0;
            background:#000;
            backdrop-filter:blur(10px);
        }

        .logo{
            font-size:2rem;
            font-weight:bold;
            color:#1DB954;
        }

        .nav-links{
            display:flex;
            gap:20px;
            align-items:center;
        }

        .nav-links a{
            color:white;
            text-decoration:none;
            transition:0.3s;
            font-size:0.95rem;
        }

        .nav-links a:hover{
            color:#1DB954;
        }

        .login-btn{
            padding:10px 18px;
            background:#1DB954;
            color:black !important;
            border-radius:10px;
            font-weight:bold;
        }

        .hero{
            min-height:90vh;
            display:flex;
            flex-direction:column;
            justify-content:center;
            align-items:center;
            text-align:center;
            padding:40px 20px;
        }

        .hero h1{
            font-size:4rem;
            max-width:900px;
            line-height:1.1;
            margin-bottom:25px;
        }

        .hero span{
            color:#1DB954;
        }

        .hero p{
            color:#b3b3b3;
            max-width:700px;
            font-size:1.1rem;
            line-height:1.7;
            margin-bottom:40px;
        }

        .hero-buttons{
            display:flex;
            gap:20px;
            flex-wrap:wrap;
            justify-content:center;
        }

        .primary-btn{
            padding:15px 28px;
            background:#1DB954;
            color:black;
            border-radius:12px;
            text-decoration:none;
            font-weight:bold;
            transition:0.3s;
        }

        .secondary-btn{
            padding:15px 28px;
            border:1px solid rgba(255,255,255,0.15);
            color:white;
            border-radius:12px;
            text-decoration:none;
            transition:0.3s;
        }

        .primary-btn:hover,
        .secondary-btn:hover{
            transform:translateY(-3px);
        }

        .features{
            padding:80px 8%;
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
            gap:25px;
        }

        .card{
            background:#111;
            padding:30px;
            border-radius:20px;
            border:1px solid rgba(29,185,84,0.12);
            transition:0.3s;
        }

        .card:hover{
            transform:translateY(-5px);
            border-color:#1DB954;
        }

        .card h3{
            margin-bottom:15px;
            color:#1DB954;
        }

        .card p{
            color:#aaa;
            line-height:1.6;
        }

        footer{
            padding:30px;
            text-align:center;
            color:#666;
            border-top:1px solid rgba(255,255,255,0.08);
        }

        @media(max-width:768px){

            .hero h1{
                font-size:2.5rem;
            }

            .nav-links{
                gap:12px;
            }

        }

    </style>

</head>
<body>

    <nav>

        <div class="logo">Finn</div>

        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/users/login">Login</a>
            <a href="/users/register" class="login-btn">Get Started</a>
        </div>

    </nav>

    <section class="hero">

        <h1>
            Smarter Money Decisions with <span>AI</span>
        </h1>

        <p>
            Finn helps you track expenses, manage finances, 
            and receive intelligent financial insights through 
            a modern AI-powered assistant.
        </p>

        <div class="hero-buttons">

            <a href="/users/register" class="primary-btn">
                Start Free
            </a>

            <a href="/users/login" class="secondary-btn">
                Login
            </a>

        </div>

    </section>

    <section class="features">

        <div class="card">
            <h3>AI Financial Coach</h3>
            <p>
                Get intelligent financial suggestions and 
                personalized insights instantly.
            </p>
        </div>

        <div class="card">
            <h3>Expense Tracking</h3>
            <p>
                Track daily spending and monitor your 
                financial habits with ease.
            </p>
        </div>

        <div class="card">
            <h3>Smart Dashboard</h3>
            <p>
                Visualize income, expenses, and savings 
                in one minimal interface.
            </p>
        </div>

    </section>

    <footer>
        © 2026 Finn. AI Finance Simplified.
    </footer>

</body>
</html>